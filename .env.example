# XpelBeauty Hostinger — environment variables
# Copy this file to .env and fill in the values for local development.
# For production, set these in Hostinger's environment / build pipeline.

# Base URL of the PHP API (relative path works when served from the same domain)
VITE_API_BASE=/api

# Secret token that protects all write operations (POST/PUT/DELETE to the API).
# Must match the API_TOKEN constant in public/api/config.php (or xpel-config.php).
# Use a long random string — e.g. openssl rand -hex 32
VITE_API_TOKEN=change-me-to-a-long-random-string

# Optional: override in CI/build pipelines only
# VITE_ADMIN_USER=admin
# VITE_ADMIN_PASS=xpel2026
